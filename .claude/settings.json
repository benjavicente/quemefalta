{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint 1>&2 || exit 2",
            "if": "Bash(git commit*)",
            "timeout": 60,
            "statusMessage": "Lint (eslint --fix) antes del commit..."
          }
        ]
      }
    ]
  }
}
